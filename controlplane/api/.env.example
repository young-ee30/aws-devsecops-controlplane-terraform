# 로컬 API 서버 포트
PORT=4000

# 실행 환경: development | production
NODE_ENV=development

# CORS 허용 프론트 주소
# 로컬 대시보드 주소:
FRONTEND_ORIGIN=http://localhost:5173

# GitHub 저장소 위치
# 개인 계정 예시:
# GITHUB_OWNER=young-ee30
# 조직 예시:
# GITHUB_OWNER=aws-security-project
GITHUB_OWNER=young-ee30
GITHUB_REPO=aws-security-project

# GitHub App 페이지 -> General 에서 확인하는 값
GITHUB_APP_ID=1234567
GITHUB_APP_CLIENT_ID=Iv1.0123456789abcdef

# GitHub App 개인키는 아래 둘 중 하나로 넣습니다
# 1) 줄바꿈을 \n 으로 바꾼 PEM 텍스트 한 줄
# 2) 다운로드한 .pem 파일의 절대 경로
# 예시:
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY="C:\Users\User\Desktop\github-app-private-key.pem"
GITHUB_APP_PRIVATE_KEY=""

# 지금 로컬 MVP는 webhook 대신 polling을 쓰므로 비워둬도 됩니다
GITHUB_WEBHOOK_SECRET=

# LLM 설정
# 실제 API 키는 .env에만 넣고 git에는 올리지 않습니다
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-5.4-mini
